{
  "name": "doki-master-theme",
  "packageManager": "yarn@4.17.1",
  "private": true,
  "workspaces": [
    "doki-build-source/",
    "buildSrc/",
    "../doki-build-source"
  ],
  "scripts": {
    "getDokiBuildSrc": "git clone https://github.com/ZimCodes/doki-build-source.git",
    "buildDokiSrc": "yarn workspace doki-build-source build",
    "generateIconsTemplates": "yarn workspace master-theme-build generateIconsTemplates",
    "generateJetbrainsTemplates": "yarn workspace master-theme-build generateJetbrainsTemplates",
    "generateColors": "yarn workspace master-theme-build generateColors",
    "modifyThemes": "yarn workspace master-theme-build modifyThemes",
    "generateAllJetbrains": "yarn generateJetbrainsTemplates && yarn generateColors",
    "generateAllJetbrainsAndIcons": "yarn generateJetbrainsTemplates && yarn generateIconsTemplates && yarn generateColors",
    "generateCustomJetbrainsTemplate": "yarn workspace master-theme-build generateCustomJetbrainsTemplates",
    "generateCustomIconsTemplate": "yarn workspace master-theme-build generateCustomIconsTemplates"
  }
}
